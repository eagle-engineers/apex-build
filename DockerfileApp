FROM eclipse-temurin:17-jre

WORKDIR /app

# Create a non-privileged system user for secure application execution
RUN adduser --system --group spring
USER spring:spring

ENV DOCUMENT_UPLOAD_PATH="/Users/aravind/Desktop/aravind/eagle/eagle-site/apex-build/uploads"

# FIXED: Explicitly copy ONLY the executable bootJar artifact
COPY ./apex-app/*-SNAPSHOT.jar app.jar

# Expose your standard application listening port
EXPOSE 8081

# Optimize JVM flag allocations for quick container responsiveness
ENTRYPOINT ["java", "-XX:+UseG1GC", "-XX:+ExitOnOutOfMemoryError", "-jar", "app.jar"]

